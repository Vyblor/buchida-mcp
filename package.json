{
	"name": "@buchida/mcp",
	"version": "0.1.6",
	"description": "MCP server for the buchida email API — send emails, manage domains, and more from Claude, Cursor, or Copilot",
	"type": "module",
	"bin": {
		"buchida-mcp": "./dist/index.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"prepublishOnly": "pnpm build"
	},
	"keywords": ["buchida", "email", "mcp", "model-context-protocol", "claude", "cursor", "copilot"],
	"files": ["dist", "README.md"],
	"homepage": "https://buchida.com/docs/mcp",
	"license": "MIT",
	"author": "buchida <hello@buchida.com>",
	"repository": {
		"type": "git",
		"url": "https://github.com/Vyblor/buchida-mcp"
	},
	"engines": {
		"node": ">=20"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.12.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/node": "^22.13.14",
		"typescript": "^5.8.2",
		"vitest": "^3.1.1"
	}
}
